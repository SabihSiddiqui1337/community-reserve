{
  "indexes": [
    {
      "comment": "Grace/expiry sweeps scan reservations by status + time window.",
      "collectionGroup": "reservations",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "status", "order": "ASCENDING" },
        { "fieldPath": "startTime", "order": "ASCENDING" }
      ]
    },
    {
      "comment": "A resident's reservations, newest first.",
      "collectionGroup": "reservations",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "userId", "order": "ASCENDING" },
        { "fieldPath": "startTime", "order": "DESCENDING" }
      ]
    },
    {
      "comment": "Availability: an amenity's reservations within a day window.",
      "collectionGroup": "reservations",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "amenityId", "order": "ASCENDING" },
        { "fieldPath": "startTime", "order": "ASCENDING" }
      ]
    },
    {
      "comment": "Expiry sweep: live reservations past their end time.",
      "collectionGroup": "reservations",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "status", "order": "ASCENDING" },
        { "fieldPath": "endTime", "order": "ASCENDING" }
      ]
    },
    {
      "comment": "FIFO waitlist matching per amenity (PROJECT-BRIEF §4.5).",
      "collectionGroup": "waitlist",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "amenityId", "order": "ASCENDING" },
        { "fieldPath": "status", "order": "ASCENDING" },
        { "fieldPath": "createdAt", "order": "ASCENDING" }
      ]
    }
  ],
  "fieldOverrides": [
    {
      "comment": "Collection-group lookup of a user's memberships across all communities (sign-in onboarding gate).",
      "collectionGroup": "memberships",
      "fieldPath": "userId",
      "indexes": [
        { "queryScope": "COLLECTION_GROUP", "order": "ASCENDING" }
      ]
    }
  ]
}
